rules_version = '2';

// Dados operacionais (administradoras, planos, vendas) são lidos/escritos pelo **servidor**
// com Firebase Admin (`FIREBASE_SERVICE_ACCOUNT_JSON`). O SDK web no browser **não**
// acessa essas coleções diretamente — mantenha o bloqueio abaixo ou refine com Auth.

service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
