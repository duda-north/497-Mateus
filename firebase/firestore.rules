rules_version = '2';

// App usa apenas o SDK web no browser + login anônimo.
// Qualquer usuário anônimo pode ler/escrever nas coleções operacionais.
// Para produção com usuários reais, troque por regras baseadas em custom claims ou e-mail.

service cloud.firestore {
  match /databases/{database}/documents {

    match /administradoras/{docId} {
      allow read, write: if request.auth != null;
    }
    match /planos/{docId} {
      allow read, write: if request.auth != null;
    }
    match /vendas/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
